# Supabase Configuration
# Get these values from your Supabase project dashboard at https://supabase.com

# Supabase Project URL (e.g., https://xyzcompany.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Supabase Anon Key (public, used for client-side operations)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Service Role Key (private, server-side only - keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Application URL (for local development)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated admin emails allowed to access /admin
ADMIN_EMAILS=kimoalsalah@gmail.com

# Email Configuration (Resend)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx

# Email sender address (must be verified domain in Resend)
EMAIL_FROM=bookings@numuwhub.biz

# Admin email for booking notifications
EMAIL_TO=support@numuwhub.biz

# Google Calendar Configuration
# Base64-encoded or raw JSON service account credentials
GOOGLE_CALENDAR_CREDENTIALS=

# Calendar to create events in (defaults to primary if omitted)
GOOGLE_CALENDAR_ID=
