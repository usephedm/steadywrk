{
  "name": "steadywrk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "clean": "turbo run clean",
    "prepare": "husky",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test tests/smoke.spec.ts",
    "test:responsive": "playwright test tests/responsive-audit.spec.ts",
    "qa:responsive": "node scripts/qa/responsive-audit.mjs",
    "qa:lcp": "node scripts/qa/check-lcp.mjs"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --files-ignore-unknown=true --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.0.0",
    "typescript": "^5.8.3"
  },
  "workspaces": ["apps/*", "packages/*"],
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "dependencies": {
    "cloudinary": "^2.9.0",
    "remotion": "^4.0.438"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "^4.2.2",
    "lightningcss-linux-x64-gnu": "^1.32.0"
  }
}
